<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>

<fx:root type="HBox"
         xmlns:fx="http://javafx.com/fxml"
         spacing="10">

    <children>
        <Label fx:id="dialog"
               wrapText="true"
               maxWidth="300"/>
        <ImageView fx:id="displayPicture"
                   fitWidth="50"
                   fitHeight="50"
                   preserveRatio="true"/>
    </children>

</fx:root>